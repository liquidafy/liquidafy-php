{
    "name": "liquidafy/liquidafy-php",
    "description": "Liquidafy PHP SDK — crypto-native checkout for LATAM merchants (charges, withdrawals, refunds, webhooks, FX).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "liquidafy",
        "payments",
        "crypto",
        "usdt",
        "tron",
        "checkout",
        "gateway",
        "latam",
        "api",
        "sdk"
    ],
    "homepage": "https://liquidafy.com",
    "support": {
        "docs": "https://docs.liquidafy.com",
        "email": "support@liquidafy.com",
        "issues": "https://github.com/liquidafy/liquidafy-php/issues",
        "source": "https://github.com/liquidafy/liquidafy-php"
    },
    "authors": [
        {
            "name": "Liquidafy Labs Ltda",
            "email": "support@liquidafy.com",
            "homepage": "https://liquidafy.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Liquidafy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Liquidafy\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --no-progress"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
